# Pain Away — Backend Environment Variables

# Application
APP_NAME=painaway
APP_ENV=development
DEBUG=true

# Server
HOST=0.0.0.0
PORT=8000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=painaway
DB_PASSWORD=painaway_dev
DB_NAME=painaway

# Database URL (async)
DATABASE_URL=postgresql+asyncpg://painaway:painaway_dev@localhost:5432/painaway

# CORS
CORS_ORIGINS=["http://localhost:5173"]

# Timezone
TIMEZONE=Asia/Kolkata
